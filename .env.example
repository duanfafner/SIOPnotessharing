# ============================================
# .env.example — Copy this to .env.local
# ============================================
# Never commit .env.local to GitHub.
# Set these as environment variables in Vercel.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
# Server-side only (used by /api/moderate on Vercel)
ANTHROPIC_KEY=your_anthropic_api_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ANTHROPIC_MODEL_MODERATION=claude-sonnet-4-20250514
# Image attachment checks default to Haiku in code; set this to override (PDFs/DOCX always use MODERATION model)
ANTHROPIC_MODEL_IMAGE_MODERATION=claude-3-5-haiku-20241022
ANTHROPIC_MODEL_OCR=claude-sonnet-4-20250514
SITE_PASSWORD=your_shared_siop_password
